---
import { getCollection } from "astro:content";
import { SITE } from "@config";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import Footer from "@components/Footer.astro";
import Header from "@components/Header.astro";
import Layout from "@layouts/Layout.astro";

const projects = (
  await getCollection("projects", ({ data }) => !data.draft)
).sort((a, b) => a.data.order - b.data.order);
---

<Layout title={`Projects | ${SITE.title}`}>
  <Header activeNav="projects" />
  <Breadcrumbs />
  <main id="main-content">
    <section class="mb-28 max-w-3xl">
      <h1 class="text-3xl tracking-wider sm:text-4xl">Projects</h1>
      <p class="mt-4 mb-10 opacity-80">
        Sites and applications I've built and maintain.
      </p>
      <div class="flex flex-col gap-8">
        {
          projects.map(project => (
            <a
              href={`/projects/${project.id}/`}
              class="project-card group block rounded-xl border border-skin-line bg-skin-card p-5 transition-all hover:border-skin-accent/50"
            >
              <div class="overflow-hidden rounded-lg border border-skin-line">
                <img
                  src={project.data.image}
                  alt={`Screenshot of ${project.data.title}`}
                  class="w-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
                  loading="lazy"
                />
              </div>
              <div class="mt-4">
                <h2 class="inline-flex items-center gap-2 text-xl font-semibold text-skin-accent">
                  {project.data.title}
                </h2>
                <p class="mt-2 text-sm opacity-80">
                  {project.data.description}
                </p>
                <div class="mt-3 flex flex-wrap gap-2">
                  {project.data.tags.map(tag => (
                    <span class="rounded-full bg-skin-card-muted px-3 py-0.5 text-xs font-medium opacity-90">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
            </a>
          ))
        }
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  #main-content {
    @apply mx-auto max-w-3xl px-4;
  }
</style>
