---
import { SITE } from "@config";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import Footer from "@components/Footer.astro";
import Header from "@components/Header.astro";
import Layout from "./Layout.astro";

export interface Props {
  frontmatter: {
    title: string;
    description?: string;
  };
}

const { frontmatter } = Astro.props;
---

<Layout title={`${frontmatter.title} | ${SITE.title}`}>
  <Header activeNav="oss" />
  <Breadcrumbs />
  <main id="main-content">
    <section id="oss" class="prose mb-28 max-w-3xl prose-img:border-0">
      <h1 class="text-3xl tracking-wider sm:text-4xl">{frontmatter.title}</h1>
      <slot />
    </section>
  </main>
  <Footer />
</Layout>

<style>
  #main-content {
    @apply mx-auto max-w-3xl px-4;
  }
  #oss {
    @apply max-w-3xl;
  }

  /* Professional touches for the OSS page */
  :global(.prose h2) {
    @apply mt-12 mb-6 border-b border-skin-line pb-2 font-bold !text-skin-accent;
  }
  :global(.prose h3) {
    @apply mt-8 mb-2 text-xl font-bold !not-italic !text-skin-base;
  }
  :global(.prose h3 a) {
    @apply no-underline hover:underline hover:text-skin-accent transition-colors;
  }
  :global(.prose ul) {
    @apply list-none pl-0;
  }
  :global(.prose li) {
    @apply mb-4 relative pl-6;
  }
  :global(.prose li::before) {
    content: "→";
    @apply absolute left-0 text-skin-accent font-bold;
  }
  :global(.prose li ul) {
    @apply mt-2 mb-0;
  }
  :global(.prose li ul li) {
    @apply mb-1 text-sm opacity-90;
  }
  :global(.prose li ul li::before) {
    content: "•";
    @apply text-skin-base font-normal;
  }
  /* Expandable OSS boxes */
  :global(.prose details.oss-box) {
    @apply mb-4 rounded-xl border border-skin-line bg-skin-card transition-colors;
  }
  :global(.prose details.oss-box[open]) {
    @apply border-skin-accent/50;
  }
  :global(.prose details.oss-box > summary) {
    @apply flex cursor-pointer list-none items-center justify-between gap-3 rounded-xl px-5 py-4 font-semibold;
  }
  :global(.prose details.oss-box > summary::-webkit-details-marker) {
    display: none;
  }
  :global(.prose details.oss-box > summary::after) {
    content: "+";
    @apply ml-auto text-xl font-normal text-skin-accent transition-transform;
  }
  :global(.prose details.oss-box[open] > summary::after) {
    content: "−";
  }
  :global(.prose .oss-box-title) {
    @apply text-lg text-skin-accent;
  }
  :global(.prose .oss-box-role) {
    @apply ml-3 rounded-full bg-skin-card-muted px-3 py-0.5 text-xs font-medium opacity-90;
  }
  /* Reset prose list spacing inside boxes and pad the body */
  :global(.prose details.oss-box > *:not(summary)) {
    @apply px-5;
  }
  :global(.prose details.oss-box > *:not(summary):last-child) {
    @apply pb-5;
  }
  :global(.prose details.oss-box > ul) {
    @apply mt-0;
  }

  :global(.prose blockquote) {
    @apply mt-16 border-l-4 border-skin-accent bg-skin-card/30 py-4 px-6 rounded-r-lg italic;
  }
  :global(.prose blockquote p) {
    @apply m-0;
  }
  :global(.prose strong) {
    @apply text-skin-accent font-semibold;
  }
</style>
